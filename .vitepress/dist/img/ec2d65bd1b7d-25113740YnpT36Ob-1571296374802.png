    <style>
        :root {
            --color-white: #ffffff;
            --color-zinc-900: #18181b;
            --color-border-subtle: #e4e4e7;
            --color-link: #0052cc;
            --color-link-blue: #0065ff;
            --color-info-bg: #fff5f2;
            --color-info-border: #ffbdad;
            --font-heading: 'Titillium Web', sans-serif;
            --font-body: 'Inter', sans-serif;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: var(--font-body);
            background-color: var(--color-white);
            color: var(--color-zinc-900);
            line-height: 1.5;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .header {
            height: 48px;
            width: 100%;
            background-color: var(--color-white);
            display: flex;
            align-items: center;
            padding: 0 24px;
            border-bottom: 1px solid var(--color-border-subtle);
            position: relative;
        }

        .logo {
            height: 32px;
            width: auto;
            min-width: 180px;
            background-image: url('data:image/svg+xml;base64,');
            background-size: contain;
            background-repeat: no-repeat;
            background-position: left center;
        }

        .main-container {
            flex: 1;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 0;
        }

        .content-wrapper {
            max-width: 760px;
            width: 100%;
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .error-section {
            display: flex;
            flex-direction: column;
            gap: 7px;
            align-items: center;
            text-align: center;
        }

        .illustration-container {
            padding: 9px 0 0;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .error-illustration {
            width: 250px;
            height: 150px;
            background-image: url('data:image/gif;base64,');
            background-size: cover;
            background-repeat: no-repeat;
            background-position: center;
        }

        .error-title {
            font-family: var(--font-heading);
            font-size: 60px;
            font-weight: 700;
            line-height: 90px;
            color: var(--color-zinc-900);
            margin: 0;
        }

        .error-content {
            display: flex;
            flex-direction: column;
            gap: 7px;
            width: 100%;
            padding: 0 11px;
        }

        .error-description {
            font-size: 16px;
            line-height: 24px;
            color: var(--color-zinc-900);
            text-align: center;
        }

        .error-support {
            font-size: 16px;
            line-height: 24px;
            color: var(--color-zinc-900);
            text-align: center;
        }

        .support-link {
            color: var(--color-link);
            text-decoration: underline;
            font-weight: 500;
        }

        .support-link:hover {
            text-decoration: none;
        }

        .info-box {
            background-color: var(--color-info-bg);
            border: 1px solid var(--color-info-border);
            border-radius: 12px;
            padding: 24px;
            font-size: 14px;
            line-height: 24px;
            color: var(--color-zinc-900);
            text-align: left;
            display: flex;
            flex-direction: column;
            gap: 16px;
            /* CSS containment to prevent style bleeding */
            contain: layout style;
            /* Ensure consistent box model */
            box-sizing: border-box;
        }

        /* Reset and isolate content within info-box */
        .info-box * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        /* Typography for injected content */
        .info-box h1,
        .info-box h2,
        .info-box h3,
        .info-box h4,
        .info-box h5,
        .info-box h6 {
            font-family: var(--font-heading);
            font-weight: 600;
            color: var(--color-zinc-900);
            margin: 0 0 12px 0;
            line-height: 1.3;
        }

        .info-box h1 { font-size: 20px; }
        .info-box h2 { font-size: 18px; }
        .info-box h3 { font-size: 16px; }
        .info-box h4 { font-size: 15px; }
        .info-box h5 { font-size: 14px; }
        .info-box h6 { font-size: 13px; }

        .info-box p {
            font-family: var(--font-body);
            font-size: 14px;
            line-height: 20px;
            color: var(--color-zinc-900);
            margin: 0 0 12px 0;
        }

        .info-box p:last-child {
            margin-bottom: 0;
        }

        .info-box ul,
        .info-box ol {
            font-family: var(--font-body);
            font-size: 14px;
            line-height: 20px;
            color: var(--color-zinc-900);
            margin: 0 0 12px 0;
            padding-left: 20px;
        }

        .info-box li {
            margin: 0 0 6px 0;
            padding: 0;
        }

        .info-box li:last-child {
            margin-bottom: 0;
        }

        .info-box a {
            color: var(--color-link);
            text-decoration: underline;
            font-weight: 500;
        }

        .info-box a:hover {
            text-decoration: none;
        }

        .info-box strong,
        .info-box b {
            font-weight: 600;
            color: var(--color-zinc-900);
        }

        .info-box em,
        .info-box i {
            font-style: italic;
        }

        .info-box code {
            font-family: 'Courier New', monospace;
            font-size: 13px;
            background-color: rgba(0, 0, 0, 0.05);
            padding: 2px 4px;
            border-radius: 3px;
            color: var(--color-zinc-900);
        }

        .info-box pre {
            font-family: 'Courier New', monospace;
            font-size: 13px;
            background-color: rgba(0, 0, 0, 0.05);
            padding: 12px;
            border-radius: 6px;
            color: var(--color-zinc-900);
            overflow-x: auto;
            margin: 0 0 12px 0;
        }

        .info-box blockquote {
            border-left: 3px solid var(--color-info-border);
            padding-left: 16px;
            margin: 0 0 12px 0;
            font-style: italic;
            color: var(--color-zinc-900);
        }

        /* Ensure nested elements don't break layout */
        .info-box div,
        .info-box span {
            color: inherit;
            font-family: inherit;
            font-size: inherit;
            line-height: inherit;
        }

        .info-box-site {
            font-family: var(--font-heading);
            font-size: 20px;
            font-weight: 600;
            line-height: 27px;
            color: var(--color-link-blue);
            margin: 0;
        }

        .info-box-title {
            font-family: var(--font-heading);
            font-size: 20px;
            font-weight: 600;
            line-height: 27px;
            color: var(--color-zinc-900);
            margin: 0;
        }

        .info-box-description {
            font-size: 14px;
            line-height: 24px;
            color: var(--color-zinc-900);
            margin: 0;
        }

        /* Responsive Design */
        @media (max-width: 768px) {
            .header {
                padding: 0 16px;
            }

            .main-container {
                align-items: flex-start;
                padding: 24px 0;
            }

            .content-wrapper {
                gap: 24px;
                padding: 0 16px;
            }

            .error-content {
                padding: 0 16px;
            }

            .error-title {
                font-size: 48px;
                line-height: 72px;
            }

            .error-illustration {
                width: 200px;
                height: 120px;
            }

            .error-illustration::before {
                font-size: 48px;
            }

            .error-illustration::after {
                width: 30px;
                height: 45px;
                top: 15px;
                right: 25px;
            }

            .info-box {
                padding: 20px 16px;
            }

            .info-box-site,
            .info-box-title {
                font-size: 18px;
                line-height: 24px;
            }
        }

        @media (max-width: 480px) {
            .error-title {
                font-size: 36px;
                line-height: 54px;
            }

            .error-illustration {
                width: 180px;
                height: 100px;
            }

            .error-illustration::before {
                font-size: 36px;
            }

            .error-description,
            .error-support {
                font-size: 14px;
                line-height: 20px;
            }

            .content-wrapper {
                gap: 20px;
            }

            .error-section {
                gap: 20px;
            }

            .info-box-site,
            .info-box-title {
                font-size: 16px;
                line-height: 22px;
            }
        }

        @media (min-width: 1200px) {
            .content-wrapper {
                gap: 48px;
            }
        }
    </style>
<meta http-equiv="refresh" content="360"></head>
<body>
    <header class="header">
        <div class="logo"></div>
    </header>

    <main class="main-container">
        <div class="content-wrapper">
            <section class="error-section">
                <div class="illustration-container">
                    <div class="error-illustration" role="img" aria-label="Security check illustration"></div>
                </div>
                
                <div class="error-content">
                    <h1 class="error-title">Just a moment...</h1>
                    
                    <p class="error-description">
                        We're experiencing very high load right now. We're just checking that you're not a robot.
                    </p>
                    
                    <p class="error-support">
                        If the issue persists, <a href="/cdn-cgi/l/email-protection#30434540405f424470545f53455d555e440306001e535f5d" class="support-link">contact support</a>.
                    </p>
                </div>
